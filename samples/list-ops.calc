(define items (list 10 20 30 40))

(do
  (print "--- list ops ---")
  (print (nth 0 items))
  (print (first items))
  (print (rest items))
  (print (get items 2))
  (print (set items 1 99))
  (print (map (lambda (x) (+ x 1)) items))
  (print (select (lambda (x) (> x 20)) items))
  (print (reduce (lambda (memo x) (+ memo x)) 0 items)))
