(define items (list 10 20 30 40))

(do
  (println "--- list ops ---")
  (println (nth 0 items))
  (println (first items))
  (println (rest items))
  (println (get items 2))
  (println (set items 1 99))
  (println (map (lambda (x) (+ x 1)) items))
  (println (select (lambda (x) (> x 20)) items))
  (println (reduce (lambda (memo x) (+ memo x)) 0 items)))
