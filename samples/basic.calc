(define base 10)
(define bonus 4)

(do
  (println "--- basic ---")
  (println (+ base bonus))
  (println (- base bonus))
  (println (and (> base 5) (< bonus 10)))
  (println (or false (> base bonus)))
  (println (not (== base bonus)))
  (println (cond
           ((> base bonus) "base>bonus")
           ((== base bonus) "equal")
           (else "base<bonus")))
  (if (> (+ base bonus) 12)
      (+ base bonus)
      (- base bonus)))
