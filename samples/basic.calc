(define base 10)
(define bonus 4)

(do
  (print "--- basic ---")
  (print (+ base bonus))
  (print (- base bonus))
  (print (and (> base 5) (< bonus 10)))
  (print (or false (> base bonus)))
  (print (not (== base bonus)))
  (print (cond
           ((> base bonus) "base>bonus")
           ((== base bonus) "equal")
           (else "base<bonus")))
  (if (> (+ base bonus) 12)
      (+ base bonus)
      (- base bonus)))
