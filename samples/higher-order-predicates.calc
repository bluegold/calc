(define values (list 1 2 3 4 5))

(do
  (println "--- higher-order predicates ---")
  (println (find (lambda (x) (> x 3)) values))
  (println (any? (lambda (x) (== x 4)) values))
  (println (all? (lambda (x) (> x 0)) values))
  (println (none? (lambda (x) (< x 0)) values))
  (println (count values))
  (count (lambda (x) (> x 2)) values))
