#!/usr/bin/env ruby

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "calc"
require "json"
require "reline"

module CalcCli
  module_function

  def tty?(io)
    io.respond_to?(:tty?) && io.tty?
  end

  def color(text, code, enabled)
    enabled ? "\e[#{code}m#{text}\e[0m" : text
  end

  def green(text, enabled)
    color(text, 32, enabled)
  end

  def red(text, enabled)
    color(text, 31, enabled)
  end

  def cyan(text, enabled)
    color(text, 36, enabled)
  end
end

parser = Calc::Parser.new
executer = Calc::Executer.new
builtins = executer.instance_variable_get(:@builtins)
completion = Calc::ReplCompletion.new(
  builtins,
  symbol_candidates_provider: ->(namespace_path) { executer.completion_candidates(namespace_path: namespace_path) }
)
history_path = File.join(Dir.home, ".calc_history")
print_last_result = false
script_path = nil
subcommand = nil
remaining_args = []

Reline.completion_proc = proc do |fragment|
  completion.candidates(fragment, Reline.line_buffer.to_s, Reline.point || 0)
end
Reline.autocompletion = true

argv = ARGV.dup

subcommand = argv.shift if argv.first == "test"

argv.each do |arg|
  case arg
  when "--print-last-result"
    print_last_result = true
  when /^-/
    warn "unknown option: #{arg}"
    exit 1
  else
    if subcommand == "test"
      remaining_args << arg
    else
      script_path ||= arg
    end
  end
end

if File.file?(history_path)
  contents = File.read(history_path)

  begin
    entries = JSON.parse(contents)
    if entries.is_a?(Array)
      entries.each do |entry|
        next unless entry.is_a?(String)
        next if entry.strip.empty?

        Reline::HISTORY << entry
      end
    else
      contents.each_line(chomp: true).each do |entry|
        next if entry.strip.empty?

        Reline::HISTORY << entry
      end
    end
  rescue JSON::ParserError
    contents.each_line(chomp: true).each do |entry|
      next if entry.strip.empty?

      Reline::HISTORY << entry
    end
  end
elsif File.exist?(history_path)
  warn "ignoring non-regular history file: #{history_path}"
end

def run_calc_tests(executer, paths)
  explicit_targets = !paths.empty?
  test_paths = explicit_targets ? paths.flat_map { |path| collect_test_files(path) }.uniq : default_test_paths

  if explicit_targets && test_paths.empty?
    warn "no .calc test files matched: #{paths.join(' ')}"
    return 1
  end

  if test_paths.empty?
    warn "no .calc test files found"
    return 1
  end

  stdout_colorize = CalcCli.tty?($stdout)
  stderr_colorize = CalcCli.tty?($stderr)
  total = test_paths.length
  passed = 0
  failures = []

  puts CalcCli.cyan("Running #{total} calc tests", stdout_colorize)

  test_paths.each do |path|
    source = File.read(path)
    begin
      result = executer.evaluate_source(source, source_path: File.expand_path(path))
      passed += 1
      puts CalcCli.green("PASS", stdout_colorize) + " #{path}"
      puts Calc.format_value(result) unless result.nil?
    rescue StandardError => e
      failures << path
      warn CalcCli.red("FAIL", stderr_colorize) + " #{path}: #{e.class}: #{e.message}"
    end
  end

  failed = failures.length
  summary = "#{passed} passed, #{failed} failed"
  puts CalcCli.cyan(summary, stdout_colorize)

  failures.empty? ? 0 : 1
end

def default_test_paths
  %w[stdlib/test modules/test samples/test]
    .select { |path| Dir.exist?(path) }
    .flat_map { |path| collect_test_files(path) }
end

def collect_test_files(path)
  return [path] if File.file?(path) && path.end_with?(".calc")

  return [] unless Dir.exist?(path)

  Dir.glob(File.join(path, "**", "*.calc"))
end

def handle_repl_command(line, parser, _executer, builtins)
  command, payload = line[1..].split(/\s+/, 2)

  case command
  when "ast"
    source = payload.to_s.strip
    puts Calc::ASTPrinter.pretty(parser.parse(source))
    true
  when "help"
    puts "Commands:"
    puts "  :ast <expr>   Print the AST for an expression"
    puts "  :help         Show this help"
    puts
    puts "Builtins:"
    builtins.each_builtin.group_by { |builtin| builtin.type || "other" }.sort.each do |type, entries|
      puts "  [#{format_builtin_group(type)}]"
      entries.sort_by(&:name).each do |builtin|
        line = "    #{builtin.name}"
        line += " - #{builtin.description}" if builtin.description
        puts line
        puts "      example: #{builtin.example}" if builtin.example
      end
    end
    true
  else
    warn "unknown command: :#{command}"
    false
  end
rescue StandardError => e
  warn "#{e.class}: #{e.message}"
  false
end

def format_builtin_group(type)
  type.split("-").map(&:capitalize).join(" ")
end

def paren_depth(source)
  depth = 0

  source.each_line do |line|
    code = line.sub(/;.*$/, "")

    code.each_char do |char|
      case char
      when "("
        depth += 1
      when ")"
        depth -= 1
        return depth if depth.negative?
      end
    end
  end

  depth
end

def balanced_parens?(source)
  paren_depth(source).zero?
end

def unmatched_closing_paren?(source)
  paren_depth(source).negative?
end

def prompt_for(buffer)
  buffer.empty? ? "> " : "... "
end

exit run_calc_tests(executer, remaining_args) if subcommand == "test"

if script_path
  source = File.read(script_path)
  last_result = executer.evaluate_source(source, source_path: File.expand_path(script_path))

  puts Calc.format_value(last_result) if print_last_result && !last_result.nil?
else
  buffer = +""

  loop do
    line = Reline.readline(prompt_for(buffer), false)
    break unless line

    next if buffer.empty? && line.strip.empty?

    buffer << line << "\n"

    if unmatched_closing_paren?(buffer)
      warn "unexpected ')'"
      buffer.clear
      next
    end

    next unless balanced_parens?(buffer)

    source = buffer.strip
    buffer.clear

    next if source.empty?

    if source.start_with?(":")
      Reline::HISTORY << source if handle_repl_command(source, parser, executer, builtins)
      next
    end

    last_result = nil
    parser.parse(source).each do |node|
      last_result = executer.evaluate(node)
    end

    puts Calc.format_value(last_result) unless last_result.nil?

    Reline::HISTORY << source
  rescue StandardError => e
    warn "#{e.class}: #{e.message}"
    buffer.clear
  end

  begin
    File.write(history_path, JSON.pretty_generate(Reline::HISTORY.to_a))
  rescue SystemCallError => e
    warn "failed to write history: #{e.message}"
  end
end
