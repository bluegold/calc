#!/usr/bin/env ruby

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "calc"
require "reline"

parser = Calc::Parser.new
executer = Calc::Executer.new
history_path = File.join(Dir.home, ".calc_history")

if File.exist?(history_path)
  File.readlines(history_path, chomp: true).each do |entry|
    Reline::HISTORY << entry unless entry.strip.empty?
  end
end

def handle_repl_command(line, parser, executer)
  command, payload = line[1..].split(/\s+/, 2)

  case command
  when "ast"
    source = payload.to_s.strip
    parser.parse(source).each do |node|
      puts Calc::ASTPrinter.pretty(node)
    end
  else
    warn "unknown command: :#{command}"
  end
end

if ARGV.first
  source = File.read(ARGV.first)
  parser.parse(source).each { |node| executer.evaluate(node) }
else
  loop do
    line = Reline.readline("> ", true)
    break unless line

    next if line.strip.empty?

    if line.start_with?(":")
      handle_repl_command(line, parser, executer)
      next
    end

    parser.parse(line).each do |node|
      puts executer.evaluate(node)
    end
  end

  File.write(history_path, Reline::HISTORY.to_a.join("\n") + "\n")
end
