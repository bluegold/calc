(do
  (load "collections/list")
  (assert-equal 6 (std.collections.list.sum (list 1 2 3)))
  (assert-equal 3 (std.collections.list.count (list 1 2 3)))
  (assert-equal 2 (std.collections.list.average (list 1 2 3)))
  (assert-equal 1 (std.collections.list.min (list 1 2 3)))
  (assert-equal 3 (std.collections.list.max (list 1 2 3)))
  (assert-equal -5 (std.collections.list.min (list -1 -5 3 2)))
  (assert-equal 3 (std.collections.list.max (list -1 -5 3 2)))
  (assert-equal 2.5 (std.collections.list.min (list 3.1 2.5 7.8)))
  (assert-equal 7.8 (std.collections.list.max (list 3.1 2.5 7.8)))
  (assert-equal 42 (std.collections.list.min (list 42)))
  (assert-equal 42 (std.collections.list.max (list 42)))
  (assert-equal 3 (std.collections.list.last (list 1 2 3)))
  (assert-equal (list 3 2 1) (std.collections.list.reverse (list 1 2 3)))
  (assert-equal (list 1 2 3 4) (std.collections.list.append-all (list (list 1 2) (list 3 4))))
  true)
