(do
  (load "math/stats")
  (assert-equal 6 (std.math.stats.sum (list 1 2 3)))
  (assert-equal 3 (std.math.stats.count (list 1 2 3)))
  (assert-equal 2 (std.math.stats.mean (list 1 2 3)))
  (assert-equal 1 (std.math.stats.min (list 1 2 3)))
  (assert-equal 3 (std.math.stats.max (list 1 2 3)))
  (assert-equal -5 (std.math.stats.min (list -1 -5 3 2)))
  (assert-equal 3 (std.math.stats.max (list -1 -5 3 2)))
  (assert-equal 2.5 (std.math.stats.min (list 3.1 2.5 7.8)))
  (assert-equal 7.8 (std.math.stats.max (list 3.1 2.5 7.8)))
  (assert-equal 42 (std.math.stats.min (list 42)))
  (assert-equal 42 (std.math.stats.max (list 42)))
  true)
